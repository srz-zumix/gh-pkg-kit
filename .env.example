# .env.example
# Copy to .env and fill in your tokens.
# This file is loaded automatically on startup (via godotenv).
# NEVER commit .env to version control.

# Token for github.com
# Priority: GH_TOKEN > GITHUB_TOKEN > `gh auth` config
#GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Token for GitHub Enterprise Server (any GHES host)
# Priority: GH_ENTERPRISE_TOKEN > GITHUB_ENTERPRISE_TOKEN > `gh auth` config
# NOTE: Container registry (containers.<host>) requires a classic PAT.
#       Fine-grained tokens and OAuth App tokens may be rejected by GHES
#       container registries even with write:packages scope.
#       Create a classic PAT at: https://<your-ghes-host>/settings/tokens
#GH_ENTERPRISE_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Token for source owner in migrate commands
# Priority: --src-token flag > GH_SRC_TOKEN > source `gh auth` config
#GH_SRC_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Token for destination owner in migrate commands
# Priority: --dst-token flag > GH_DST_TOKEN > destination `gh auth` config
#GH_DST_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
